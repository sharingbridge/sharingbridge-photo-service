PORT=8092
DATABASE_URL=postgresql://sharingbridge:sharingbridge@localhost:5432/sharingbridge

AUTH_TOKEN_SECRET=sharingbridge-dev-secret-change-me
AUTH_TOKEN_ISSUER=sharingbridge-user-service
AUTH_TOKEN_AUDIENCE=sharingbridge-clients

# Cloudinary (required) — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Or set CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Logging: error | warn (default) | info | debug — warn = issues only at startup
LOG_LEVEL=warn
